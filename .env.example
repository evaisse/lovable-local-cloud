# =============================================================================
# lovable-local-cloud — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed.
# These are LOCAL DEVELOPMENT ONLY defaults. Do NOT use in production.
# =============================================================================

# === Target App ===
# Absolute or relative path to the exported Lovable app repo on your host machine
TARGET_APP_PATH=../my-lovable-app

# === Postgres ===
POSTGRES_PASSWORD=postgres-local-dev
POSTGRES_DB=postgres
POSTGRES_PORT=54322

# === Supabase Core ===
# These are LOCAL DEV ONLY secrets. Do NOT use in production.
# JWT secret used to sign tokens (min 32 chars)
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters!!
# Anonymous key (public, safe for frontend)
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
# Service role key (secret, server-side only — NEVER expose to frontend)
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# === API Gateway ===
API_EXTERNAL_URL=http://localhost:54321
SUPABASE_PUBLIC_URL=http://localhost:54321

# === Frontend ===
FRONTEND_PORT=3000
SITE_URL=http://localhost:3000

# === Supabase env vars injected into frontend build ===
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
VITE_SUPABASE_PROJECT_ID=local

# === MailHog ===
MAILHOG_PORT=8025
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_ADMIN_EMAIL=admin@localhost
SMTP_SENDER_NAME=Lovable Local

# === Auth ===
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_MAILER_AUTOCONFIRM=false
GOTRUE_SMTP_HOST=mailhog
GOTRUE_SMTP_PORT=1025
GOTRUE_SMTP_ADMIN_EMAIL=admin@localhost
GOTRUE_SMTP_SENDER_NAME=Lovable Local

# === Realtime ===
REALTIME_PORT=4000

# === Storage ===
STORAGE_BACKEND=file
FILE_SIZE_LIMIT=52428800
